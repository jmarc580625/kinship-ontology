@prefix : <http://example.org/kinship#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

#---------------------------
# Module Declaration
#---------------------------

<http://example.org/kinship/core-neutral> a owl:Ontology ;
    owl:versionInfo "1.0.0" ;
    owl:versionIRI <http://example.org/kinship/core-neutral/1.0.0> ;
    owl:imports <http://example.org/kinship/foundation> ;
    rdfs:label "Core Family Relationships Gender-Neutral Module of the Kinship Ontology"@en ;
    rdfs:comment "Core gender-neutral family relationships: spouse, parent, child, sibling, adoptive, and partner relationships."@en ;
    dc:creator "Kinship Ontology Project" ;
    dc:date "2026-01-03"^^xsd:date ;
    dcterms:license <https://opensource.org/licenses/MIT> .

#---------------------------
# Core gender-neutral family relationships
#---------------------------

## Partnership-based relationships

### Partner - generic parental partnership 
:hasPartner a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasRelative ;
    rdfs:label "Has Partner"@en ;
    rdfs:comment "Abstract superproperty for all couple relationships regardless of legal form. Usage: assert a specific subproperty when the form is known; assert :hasPartner directly only when genuinely unknown."@en ;    
    rdf:type owl:SymmetricProperty, owl:IrreflexiveProperty ;
    :crossesAlliance true .

### spouse
:hasSpouse a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasPartner ;
    rdfs:label "Has Spouse"@en ;
    rdfs:comment "Formal marriage between two persons. Usage: use :hasPartner when the legal form is unknown or irrelevant."@en ;
    rdf:type owl:SymmetricProperty, owl:IrreflexiveProperty .

### civil partner
:hasCivilPartner a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasPartner ;
    rdfs:label "Has Civil Partner"@en ;
    rdfs:comment "Legal civil union distinct from marriage (e.g. PACS, UK civil partnership)."@en ;    
    rdf:type owl:SymmetricProperty, owl:IrreflexiveProperty .

### life partner
:hasLifePartner a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasPartner ;
    rdfs:label "Has Life Partner"@en ;
    rdfs:comment "Stable couple relationship with no legal formalization."@en ;    
    rdf:type owl:SymmetricProperty, owl:IrreflexiveProperty .

## Blood-based relationships

### descendant
:hasDescendant a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasLineageRelative ;
    rdfs:label "Has Descendant"@en ;
    rdfs:comment """Blood-only closure over :hasBloodChild. 
    Design: adoption excluded — :hasAdoptiveChild is not a subproperty of this."""@en ;
    owl:inverseOf :hasAncestor ;
    a owl:TransitiveProperty.

### ancestor
:hasAncestor a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasLineageRelative ;
    rdfs:label "Has Ancestor"@en ;
    rdfs:comment """Blood-only closure over :hasBloodParent. 
    Design: adoption excluded — :hasAdoptiveParent is not a subproperty of this."""@en ;
    owl:inverseOf :hasDescendant ;
    a owl:TransitiveProperty.

### child
:hasChild a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasRelative ;
    rdfs:label "Has Child"@en ;
    rdfs:comment """Biological or adoptive child — inclusive superproperty. 
    Design: not a subproperty of :hasDescendant; blood lineage inference requires :hasBloodChild explicitly. 
    Usage: assert when type is unknown."""@en ;
    owl:inverseOf :hasParent ;
    a owl:AsymmetricProperty .

### biological child
:hasBloodChild a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasChild ;                 # ← hiérarchie inclusive
    rdfs:subPropertyOf :hasDescendant ;            # ← ancre la transitivité de sang
    rdfs:label "Has Biological Child"@en ;
    rdfs:comment """Biological child with confirmed birth parentage. 
    Usage: use :hasChild when the biological nature is unknown or irrelevant."""@en ;
    owl:inverseOf :hasBloodParent ;
    a owl:AsymmetricProperty .

### adoptive child
:hasAdoptiveChild a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasChild ;
    rdfs:label "Has Adoptive Child"@en ;
    rdfs:comment "Child through legal adoption, not birth. Design: excluded from :hasDescendant — adoption creates no blood lineage."@en ;
    owl:inverseOf :hasAdoptiveParent ;
    a owl:AsymmetricProperty ;
    :crossesAdoption true .

### parent
:hasParent a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasRelative ;
    rdfs:label "Has Parent"@en ;
    rdfs:comment """Biological or adoptive parent — inclusive superproperty. 
    Design: not a subproperty of :hasAncestor. 
    Usage: assert when type is unknown."""@en ;
    owl:inverseOf :hasChild ;
    a owl:AsymmetricProperty .

### biological parent
:hasBloodParent a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasParent ;                # ← hiérarchie inclusive
    rdfs:subPropertyOf :hasAncestor ;              # ← ancre la transitivité de sang
    rdfs:label "Has Biological Parent"@en ;
    rdfs:comment "Biological parent with confirmed birth parentage. Usage: use :hasParent when the biological nature is unknown or irrelevant."@en ;
    owl:inverseOf :hasBloodChild ;
    a owl:AsymmetricProperty .

### adoptive parent
:hasAdoptiveParent a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasParent ;
    rdfs:label "Has Adoptive Parent"@en ;
    rdfs:comment "Parent through legal adoption, not birth. Design: excluded from :hasAncestor — adoption creates no blood lineage."@en ;
    owl:inverseOf :hasAdoptiveChild ;
    a owl:AsymmetricProperty ;
    :crossesAdoption true .

### sibling
:hasSibling a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasCollateralRelative ;
    rdfs:label "Has Sibling"@en ;
    rdfs:comment "Shares at least one parent (biological or adoptive) — half-siblings included, step-siblings and cousins excluded."@en ;
    :MaterializationReason :IrreflexivePropertyLimitation ;
    :MaterializationScript """
        INSERT {
            ?person1 :hasSibling ?person2 . # owrl reasoner infers symmetric relationship
        }
        WHERE {
            ?parent :hasChild ?person1 .
            ?parent :hasChild ?person2 .
            FILTER(?person1 != ?person2) # Exclude reflexive relationships
        }
    """ ;
    rdf:type owl:SymmetricProperty, owl:IrreflexiveProperty .

### twin
:hasTwin a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasSibling ;
    rdfs:label "Has Twin"@en ;
    rdfs:comment """Sibling born in the same birth event. 
    Usage: assert directly — birth date evidence is required, which is outside this ontology's scope."""@en ;
    rdf:type owl:SymmetricProperty, owl:IrreflexiveProperty .
