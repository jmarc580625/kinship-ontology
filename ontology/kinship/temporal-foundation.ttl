@prefix : <http://example.org/kinship#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

#---------------------------
# Module Declaration
#---------------------------

<http://example.org/kinship/temporal> a owl:Ontology ;
    owl:versionInfo "1.0.0" ;
    owl:versionIRI <http://example.org/kinship/temporal/1.0.0> ;
    rdfs:label "Temporal Module of the Kinship Ontology"@en ;
    rdfs:comment "Temporal relationships and time intervals for kinship facts."@en ;
    dc:creator "Kinship Ontology Project" ;
    dc:date "2026-01-03"^^xsd:date ;
    dcterms:license <https://opensource.org/licenses/MIT> .

#---------------------------
# Temporal relationships
#---------------------------

## Validity interval — attachable to any fact
:ValidityInterval a owl:Class ;
    rdfs:label "Validity Interval"@en ;
    rdfs:comment """Time interval during which a fact holds. 
    Open-ended (no :validTo) means currently valid."""@en .

:validFrom a owl:DatatypeProperty ;
    rdfs:label "Valid from"@en ;
    rdfs:domain :ValidityInterval ;
    rdfs:range  xsd:date .

:validTo a owl:DatatypeProperty ;
    rdfs:label "Valid to"@en ;
    rdfs:domain :ValidityInterval ;
    rdfs:range  xsd:date ;
    rdfs:comment "Absent means currently valid (open interval)."@en .

## Imprecise date : probable interval
:PrecisionLevel a owl:Class .
:Exact     a :PrecisionLevel, owl:NamedIndividual .
:Circa     a :PrecisionLevel, owl:NamedIndividual .  # ± some years
:Decade    a :PrecisionLevel, owl:NamedIndividual .  # decade known
:Unknown   a :PrecisionLevel, owl:NamedIndividual .

:TemporalEstimate a owl:Class ;
    rdfs:label "Temporal Estimate"@en ;
    rdfs:comment """A date with explicit uncertainty.
    Usage: use when exact date is unknown but an approximation and precision level are available."""@en .

:estimatedDate  a owl:DatatypeProperty ;
    rdfs:label "Estimated date"@en ;
    rdfs:domain :TemporalEstimate ;
    rdfs:range  xsd:date .

:precision a owl:ObjectProperty ;
    rdfs:label "Precision"@en ;
    rdfs:domain :TemporalEstimate ;
    rdfs:range  :PrecisionLevel .

:marginYears a owl:DatatypeProperty ;   # ± N years around estimatedDate
    rdfs:label "Margin years"@en ;
    rdfs:comment "Uncertainty margin in years around :estimatedDate. Relevant when :precision is :Circa."@en ;
    rdfs:domain :TemporalEstimate ;
    rdfs:range  xsd:integer .