@prefix : <http://example.org/kinship#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

#---------------------------
# Master Ontology Entry Point
#---------------------------
# This file is the top-level entry point for the modular kinship ontology.
# Loading this file transitively imports all modules via owl:imports.
# For triplestore that don't support owl:imports, loading must follow a deep-first traversal of the import graph.
#
# NOTE: Kinship ontology modules have been designed to support a modular testing approach:
#   - meta, gender and lineage modules form the foundation layers for the ontology 
#   - core and anchor modules depend on lineage module
#   - extended, blended, and anchor modules depend on core module and are mutually independent
#   - gender-specific module depends on all other modules
#   - social module is independent on all other modules
#---------------------------

<http://example.org/kinship> a owl:Ontology ;
    owl:versionInfo "1.0.0" ;
    owl:versionIRI <http://example.org/kinship/1.0.0> ;
    owl:imports <http://example.org/kinship/gendered> ;
    rdfs:label "Modular Kinship Ontology"@en ;
    rdfs:comment """A comprehensive ontology for modeling complex family relationships
        including biological, adoptive, blended, and in-law relationships.
        Designed for OWL 2 RL reasoning with SPARQL-based materialization
        for relationships requiring irreflexive constraints.
        This entry point imports all modules via the transitive owl:imports chain."""@en ;
    dc:creator "Kinship Ontology Project" ;
    dc:date "2026-01-03"^^xsd:date ;
    dcterms:license <https://opensource.org/licenses/MIT> .
