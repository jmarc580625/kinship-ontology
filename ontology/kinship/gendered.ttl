@prefix : <http://example.org/kinship#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

#---------------------------
# Module Declaration
#---------------------------

<http://example.org/kinship/gendered> a owl:Ontology ;
    owl:versionInfo "1.0.0" ;
    owl:versionIRI <http://example.org/kinship/gendered/1.0.0> ;
    owl:imports <http://example.org/kinship/extended-neutral> ;
    owl:imports <http://example.org/kinship/allied-neutral> ;
    owl:imports <http://example.org/kinship/blended-neutral> ;
    owl:imports <http://example.org/kinship/anchored-neutral> ;
    rdfs:label "Gendered Family Relationships Module of the Kinship Ontology"@en ;
    rdfs:comment """All gender-specific family relationships across core, extended, allied, blended and anchored layers.
        Materialization scripts consistently query the gender-neutral parent property (forward direction)
        rather than its OWL-inferred inverse, making execution order independent of OWL reasoning timing."""@en ;
    dc:creator "Kinship Ontology Project" ;
    dc:date "2026-01-03"^^xsd:date ;
    dcterms:license <https://opensource.org/licenses/MIT> .

#---------------------------
# Gender-specific relationships
#---------------------------

## Gender-specific spouse relationships

### wife (female spouse)
:hasWife a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasSpouse ;
    rdfs:label "Has Wife"@en ;
    rdfs:range :FemalePerson ;
    rdfs:comment """Female spouse. 
    Usage: use :hasSpouse for gender-neutral queries."""@en ;
    :MaterializationReason :GenderFirewallLimitation ;
    :MaterializationScript """
        INSERT {
            ?spouse :hasWife ?wife .
        }
        WHERE {
            ?wife :hasSpouse ?spouse .
            ?wife :hasGender :Female .
        }
    """ .

### husband (male spouse)
:hasHusband a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasSpouse ;
    rdfs:label "Has Husband"@en ;
    rdfs:range :MalePerson ;
    rdfs:comment """Male spouse. 
    Usage: use :hasSpouse for gender-neutral queries."""@en ;
    :MaterializationReason :GenderFirewallLimitation ;
    :MaterializationScript """
        INSERT {
            ?spouse :hasHusband ?husband .
        }
        WHERE {
            ?husband :hasSpouse ?spouse .
            ?husband :hasGender :Male .
        }
    """ .

## Gender-specific parent relationships

### mother (female parent)
:hasMother a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasParent ;
    rdfs:label "Has Mother"@en ;
    rdfs:range :FemalePerson ;
    rdfs:comment """Female parent — inclusive (biological and adoptive). 
    Usage: use :hasParent for gender-neutral queries."""@en ;
    :MaterializationReason :GenderFirewallLimitation ;
    :MaterializationScript """
        INSERT {
            ?child :hasMother ?parent .
        }
        WHERE {
            ?child :hasParent ?parent  .
            ?parent :hasGender :Female .
        }
    """ .

### father (male parent)
:hasFather a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasParent ;
    rdfs:label "Has Father"@en ;
    rdfs:range :MalePerson ;
    rdfs:comment """Male parent — inclusive (biological and adoptive). 
    Usage: use :hasParent for gender-neutral queries."""@en ;
    :MaterializationReason :GenderFirewallLimitation ;
    :MaterializationScript """
        INSERT {
            ?child :hasFather ?parent .
        }
        WHERE {
            ?child :hasParent ?parent .
            ?parent :hasGender :Male .
        }
    """ .

## Gender-specific child relationships

### daughter (female child)
:hasDaughter a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasChild ;
    rdfs:label "Has Daughter"@en ;
    rdfs:range :FemalePerson ;
    rdfs:comment """Female child — inclusive (biological and adoptive). 
    Usage: use :hasChild for gender-neutral queries."""@en ;
    :MaterializationReason :GenderFirewallLimitation ;
    :MaterializationScript """
        INSERT {
            ?parent :hasDaughter ?child .
        }
        WHERE {
            ?parent :hasChild ?child .
            ?child :hasGender :Female .
        }
    """ .

### son (male child)
:hasSon a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasChild ;
    rdfs:label "Has Son"@en ;
    rdfs:range :MalePerson ;
    rdfs:comment """Male child — inclusive (biological and adoptive). 
    Usage: use :hasChild for gender-neutral queries."""@en ;
    :MaterializationReason :GenderFirewallLimitation ;
    :MaterializationScript """
        INSERT {
            ?parent :hasSon ?child .
        }
        WHERE {
            ?parent :hasChild ?child .
            ?child :hasGender :Male .
        }
    """ .

## Gender-specific sibling relationships

### sister (female sibling)
:hasSister a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasSibling ;
    rdfs:label "Has Sister"@en ;
    rdfs:range :FemalePerson ;
    rdfs:comment """Female sibling — shares at least one parent. 
    Usage: use :hasSibling for gender-neutral queries."""@en ;
    :MaterializationReason :GenderFirewallLimitation ;
    :MaterializationScript """
        INSERT {
            ?otherSibling :hasSister ?sibling .
        }
        WHERE {
            ?sibling :hasSibling ?otherSibling .
            ?sibling :hasGender :Female .
        }
    """ .

### brother (male sibling)
:hasBrother a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasSibling ;
    rdfs:label "Has Brother"@en ;
    rdfs:range :MalePerson ;
    rdfs:comment """Male sibling — shares at least one parent. 
    Usage: use :hasSibling for gender-neutral queries."""@en ;
    :MaterializationReason :GenderFirewallLimitation ;
    :MaterializationScript """
        INSERT {
            ?otherSibling :hasBrother ?sibling .
        }
        WHERE {
            ?sibling :hasSibling ?otherSibling .
            ?sibling :hasGender :Male .
        }
    """ .

