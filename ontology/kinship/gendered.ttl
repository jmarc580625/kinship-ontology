        WHERE {
            ?godparent :hasGodchild ?godchild .
            ?godchild :hasGender :Female .
        }
    """ .

### godson (male godchild)
:hasGodson a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasGodchild ;
    rdfs:label "Has Godson"@en ;
    rdfs:range :MalePerson ;
    rdfs:comment """Male godchild. 
    Usage: use :hasGodchild for gender-neutral queries."""@en ;
    :MaterializationReason :GenderFirewallLimitation ;
    :MaterializationScript """
        INSERT {
            ?godparent :hasGodson ?godchild .
        }
        WHERE {
            ?godparent :hasGodchild ?godchild .
            ?godchild :hasGender :Male .
        }
    """ .
