## Gender-specific family-anchored relationships

### godmother (female godparent)
:hasGodmother a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasGodparent ;
    rdfs:label "Has Godmother"@en ;
    rdfs:range :FemalePerson ;
    rdfs:comment """Female godparent. 
    Usage: use :hasGodparent for gender-neutral queries."""@en ;
    :MaterializationReason :GenderFirewallLimitation ;
    :MaterializationScript """
        INSERT {
            ?godchild :hasGodmother ?godparent .
        }
        WHERE {
            ?godchild :hasGodparent ?godparent .
            ?godparent :hasGender :Female .
        }
    """ .

### godfather (male godparent)
:hasGodfather a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasGodparent ;
    rdfs:label "Has Godfather"@en ;
    rdfs:range :MalePerson ;
    rdfs:comment """Male godparent. 
    Usage: use :hasGodparent for gender-neutral queries."""@en ;
    :MaterializationReason :GenderFirewallLimitation ;
    :MaterializationScript """
        INSERT {
            ?godchild :hasGodfather ?godparent .
