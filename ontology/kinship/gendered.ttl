## Gender-specific uncle/aunt relationships

### aunt (female uncle/aunt)
:hasAunt a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasUncleAunt ;
    rdfs:label "Has Aunt"@en ;
    rdfs:range :FemalePerson ;
    rdfs:comment """Female parent's sibling. 
    Usage: use :hasUncleAunt for gender-neutral queries."""@en ;
    :MaterializationReason :GenderFirewallLimitation ;
    :MaterializationScript """
        INSERT {
            ?nibling :hasAunt ?uncleAunt .
        }
        WHERE {
            ?nibling :hasUncleAunt ?uncleAunt .
            ?uncleAunt :hasGender :Female .
        }
    """ .

### uncle (male uncle/aunt)
:hasUncle a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasUncleAunt ;
    rdfs:label "Has Uncle"@en ;
    rdfs:range :MalePerson ;
    rdfs:comment """Male parent's sibling. 
    Usage: use :hasUncleAunt for gender-neutral queries."""@en ;
    :MaterializationReason :GenderFirewallLimitation ;
    :MaterializationScript """
        INSERT {
            ?nibling :hasUncle ?uncleAunt .
        }
        WHERE {
            ?nibling :hasUncleAunt ?uncleAunt .
            ?uncleAunt :hasGender :Male .
        }
    """ .

