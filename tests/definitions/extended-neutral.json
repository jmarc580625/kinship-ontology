        },
        {
          "n": ":zela",
          "ua": ":azura"
        }
      ]
    },
    "hasCousin": {
      "description": "hasCousin is materialized; FILTER NOT EXISTS excludes pairs that are already siblings.",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?c1 ?c2 WHERE { ?c1 :hasCousin ?c2 . } ORDER BY ?c1 ?c2",
      "expected": [
        {
          "c1": ":bob",
          "c2": ":zela"
        },
        {
          "c1": ":carol",
          "c2": ":zela"
        },
        {
          "c1": ":david",
          "c2": ":eliza"
        },
        {
          "c1": ":eliza",
          "c2": ":david"
        },
        {
          "c1": ":helen",
          "c2": ":zela"
        },
        {
          "c1": ":zela",
          "c2": ":bob"
        },
        {
          "c1": ":zela",
          "c2": ":carol"
        },
        {
