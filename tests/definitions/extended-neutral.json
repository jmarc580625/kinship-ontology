      "description": "Every hasSiblingNibling pair must also appear as a hasNibling pair.",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?ua ?n WHERE { ?ua :hasSiblingNibling ?n . FILTER NOT EXISTS { ?ua :hasNibling ?n . } }",
      "expect_empty": true
