{
  "module": "extended-neutral",
  "ontologies": [
    "ontology/kinship/extended-neutral.ttl"
  ],
  "data_files": [
    "tests/data/core-data.ttl"
  ],
  "description": "Gender-neutral extended family relationships: grandparent, nibling, cousin, great-grandparent, in-law niblings",
  "tests": {
    "hasGrandchild": {
      "description": "OWL property chain axiom derives grandchildren from two hasChild hops.",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?gp ?gc WHERE { ?gp :hasGrandchild ?gc . } ORDER BY ?gp ?gc",
      "expected": [
        {
          "gp": ":adam",
          "gc": ":bob"
        },
        {
          "gp": ":adam",
          "gc": ":carol"
        },
        {
          "gp": ":adam",
          "gc": ":helen"
        },
        {
          "gp": ":adam",
          "gc": ":zela"
        },
        {
          "gp": ":azura",
          "gc": ":david"
        },
        {
          "gp": ":azura",
          "gc": ":eliza"
        },
        {
          "gp": ":eva",
          "gc": ":bob"
        },
        {
          "gp": ":eva",
          "gc": ":carol"
        },
        {
          "gp": ":eva",
          "gc": ":helen"
        },
        {
          "gp": ":eva",
          "gc": ":zela"
        },
        {
          "gp": ":frank",
          "gc": ":zela"
        },
        {
          "gp": ":grace",
          "gc": ":zela"
        },
        {
          "gp": ":nana",
          "gc": ":iris"
        },
        {
          "gp": ":nana",
          "gc": ":luna"
        },
        {
          "gp": ":papa",
          "gc": ":jay"
        },
        {
          "gp": ":papa",
          "gc": ":mars"
        }
      ]
    },
    "hasGrandparent": {
      "description": "OWL inverseOf derives hasGrandparent from hasGrandchild.",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?person ?gp WHERE { ?person :hasGrandparent ?gp . } ORDER BY ?person ?gp",
      "expected": [
        {
          "person": ":bob",
          "gp": ":adam"
        },
        {
          "person": ":bob",
          "gp": ":eva"
        },
        {
          "person": ":carol",
          "gp": ":adam"
        },
        {
          "person": ":carol",
          "gp": ":eva"
        },
        {
          "person": ":david",
          "gp": ":azura"
        },
        {
          "person": ":eliza",
          "gp": ":azura"
        },
        {
          "person": ":helen",
          "gp": ":adam"
        },
        {
          "person": ":helen",
          "gp": ":eva"
        },
        {
          "person": ":iris",
          "gp": ":nana"
        },
        {
          "person": ":jay",
          "gp": ":papa"
        },
        {
          "person": ":luna",
          "gp": ":nana"
        },
        {
          "person": ":mars",
          "gp": ":papa"
        },
        {
          "person": ":zela",
          "gp": ":adam"
        },
        {
          "person": ":zela",
          "gp": ":eva"
        },
        {
          "person": ":zela",
          "gp": ":frank"
        },
        {
          "person": ":zela",
          "gp": ":grace"
        }
      ]
    },
    "hasGreatGrandchild": {
      "description": "Three-hop property chain derives great-grandchildren.",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?ggp ?ggc WHERE { ?ggp :hasGreatGrandchild ?ggc . } ORDER BY ?ggp ?ggc",
      "expected": [
        {
          "ggp": ":adam",
          "ggc": ":david"
        },
        {
          "ggp": ":adam",
          "ggc": ":eliza"
        },
        {
          "ggp": ":eva",
          "ggc": ":david"
        },
        {
          "ggp": ":eva",
          "ggc": ":eliza"
        }
      ]
    },
    "hasGreatGrandparent": {
      "description": "OWL inverseOf derives hasGreatGrandparent.",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?person ?ggp WHERE { ?person :hasGreatGrandparent ?ggp . } ORDER BY ?person ?ggp",
      "expected": [
        {
          "person": ":david",
          "ggp": ":adam"
        },
        {
          "person": ":david",
          "ggp": ":eva"
        },
        {
          "person": ":eliza",
          "ggp": ":adam"
        },
        {
          "person": ":eliza",
          "ggp": ":eva"
        }
      ]
    },
    "hasSiblingNibling": {
      "description": "hasSiblingNibling is inferred via OWL property chain (hasSibling ∘ hasChild). Tests blood-only niblings; in-law niblings are covered by hasNiblingInLaw (subProperty of hasNibling).",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?ua ?n WHERE { ?ua :hasSiblingNibling ?n . } ORDER BY ?ua ?n",
      "expected": [
        {
          "ua": ":abel",
          "n": ":bob"
        },
        {
          "ua": ":abel",
          "n": ":carol"
        },
        {
          "ua": ":abel",
          "n": ":helen"
        },
        {
          "ua": ":azura",
          "n": ":zela"
        },
        {
          "ua": ":bob",
          "n": ":eliza"
        },
        {
          "ua": ":carol",
          "n": ":david"
        },
        {
          "ua": ":hathor",
          "n": ":mars"
        },
        {
          "ua": ":helen",
          "n": ":david"
        },
        {
          "ua": ":helen",
          "n": ":eliza"
        },
        {
          "ua": ":hera",
          "n": ":iris"
        },
        {
          "ua": ":re",
          "n": ":luna"
        },
        {
          "ua": ":zeus",
          "n": ":jay"
        }
      ]
    },
    "hasSiblingUncleAunt": {
      "description": "OWL inverseOf derives hasSiblingUncleAunt from hasSiblingNibling. Tests blood-only uncle/aunt relationships.",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?n ?ua WHERE { ?n :hasSiblingUncleAunt ?ua . } ORDER BY ?n ?ua",
      "expected": [
