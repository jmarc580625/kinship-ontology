    "hasLineageRelative-eliza": {
      "description": "hasLineageRelative covers all blood/lineage sub-properties: hasAncestor (carol, azura, adam, eva), hasSiblingUncleAunt (bob, helen), hasCousin (david). Carl is excluded (step-parent, not lineage). Abel is excluded (godparent, ceremonial).",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?r WHERE { :eliza :hasLineageRelative ?r . } ORDER BY ?r",
