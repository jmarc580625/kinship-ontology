    "struct-hasNiblingInLaw-subOf-hasNibling": {
      "description": "Every hasNiblingInLaw pair must also appear as a hasNibling pair (rdfs:subPropertyOf propagation).",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?ua ?n WHERE { ?ua :hasNiblingInLaw ?n . FILTER NOT EXISTS { ?ua :hasNibling ?n . } }",
      "expect_empty": true
    },
