          "c2": ":iris"
        },
        {
          "c1": ":mars",
          "c2": ":jay"
        },
        {
          "c1": ":zela",
          "c2": ":helen"
        }
      ]
    },
    "hasDescendant-adam": {
      "description": "hasDescendant is blood-only (populated via hasBloodChild subproperty chain). abel is adoptive → excluded. zela's blood parents are abel+ada, not in adam's blood line → excluded. Verifies adam's full blood-descendant set.",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?d WHERE { :adam :hasDescendant ?d . } ORDER BY ?d",
      "expected": [
        {
          "d": ":azura"
        },
        {
          "d": ":bob"
        },
        {
          "d": ":carol"
        },
        {
          "d": ":david"
        },
        {
          "d": ":eliza"
        },
        {
          "d": ":helen"
        }
      ]
    },
    "hasAncestor-eliza": {
      "description": "OWL inverseOf derives hasAncestor. Verifies eliza's full ancestor set.",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?a WHERE { :eliza :hasAncestor ?a . } ORDER BY ?a",
      "expected": [
        {
          "a": ":adam"
        },
        {
          "a": ":azura"
        },
        {
          "a": ":carol"
        },
        {
          "a": ":eva"
        }
      ]
    },
    "hasNiblingInLaw": {
      "description": "OWL property chain (hasPartner ∘ hasSibling ∘ hasChild) derives in-law niblings after hasSibling is materialized. Covers all partner types (hasSpouse, hasCivilPartner, hasLifePartner). carl→david (carol's sibling bob's son); antoine→zela (azura's sibling abel's daughter); ada→bob/carol/helen (abel's sibling azura's children).",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?ua ?n WHERE { ?ua :hasNiblingInLaw ?n . } ORDER BY ?ua ?n",
      "expected": [
        {
          "ua": ":ada",
          "n": ":bob"
        },
        {
          "ua": ":ada",
          "n": ":carol"
        },
        {
          "ua": ":ada",
          "n": ":helen"
        },
        {
          "ua": ":antoine",
          "n": ":zela"
        },
        {
          "ua": ":carl",
          "n": ":david"
        },
        {
          "ua": ":hathor",
          "n": ":luna"
        },
        {
          "ua": ":hera",
          "n": ":jay"
        },
        {
          "ua": ":re",
          "n": ":mars"
        },
        {
          "ua": ":zeus",
          "n": ":iris"
        }
      ]
    },
    "hasUncleAuntInLaw": {
      "description": "OWL inverseOf derives hasUncleAuntInLaw from hasNiblingInLaw.",
      "query": "PREFIX : <http://example.org/kinship#> SELECT ?n ?ua WHERE { ?n :hasUncleAuntInLaw ?ua . } ORDER BY ?n ?ua",
